<Window x:Class="CarswithSQLDatabase.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarswithSQLDatabase"
        mc:Ignorable="d"
        Title="Car Management" Height="600" Width="900">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderThickness="2" BorderBrush="Chocolate" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="VIN" Grid.Row="0" Margin="5"/>
                <TextBox x:Name="txtVIN" Grid.Row="0" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Make" Grid.Row="1" Margin="5"/>
                <TextBox x:Name="txtMake" Grid.Row="1" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Model" Grid.Row="2" Margin="5"/>
                <TextBox x:Name="txtModel" Grid.Row="2" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Year" Grid.Row="3" Margin="5"/>
                <TextBox x:Name="txtYear" Grid.Row="3" Grid.Column="1" Margin="5"/>

                <TextBlock Text="Price" Grid.Row="4" Margin="5"/>
                <TextBox x:Name="txtPrice" Grid.Row="4" Grid.Column="1" Margin="5"/>

                <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal">
                    <Button Content="Add" Width="100" Margin="5" Click="Add_Click"/>
                    <Button Content="Update" Width="100" Margin="5" Click="Update_Click"/>
                    <Button Content="Delete" Width="100" Margin="5" Click="Delete_Click"/>
                    <Button Content="Clear" Width="100" Margin="5" Click="Clear_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid x:Name="dgCars"
                  Grid.Row="1"
                  Margin="0,10,0,0"
                  AutoGenerateColumns="False"
                  SelectionChanged="dgCars_SelectionChanged">

            <DataGrid.Columns>
                <DataGridTextColumn Header="VIN" Binding="{Binding VIN}"/>
                <DataGridTextColumn Header="Make" Binding="{Binding Make}"/>
                <DataGridTextColumn Header="Model" Binding="{Binding Model}"/>
                <DataGridTextColumn Header="Year" Binding="{Binding Year}"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>